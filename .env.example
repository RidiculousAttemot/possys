# Supabase Postgres connection string
# Get this from Supabase: Project Settings > Database > Connection string > URI
SUPABASE_DB_URL=postgresql://postgres.gvppkrwfxxttrsxghjes:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase publishable key (used by frontend when needed)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Supabase Storage settings for product photos
# Create a public bucket with this name or let the server create it with a service role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=product-images

# Optional: set to false only for local/dev DB without SSL
SUPABASE_DB_SSL=true

# Optional server settings
PORT=5000
DB_POOL_MAX=10
