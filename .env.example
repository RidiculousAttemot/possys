# Server Configuration
PORT=5000               # Port the server will run on

# Database Configuration
DB_HOST=localhost       # Database host (default is localhost)
DB_USER=root            # MySQL database user
DB_PASSWORD=            # Your MySQL database password (leave empty if no password)
DB_NAME=morpos          # The database name for your POS system

# JWT Configuration
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MINIMUM_32_CHARACTERS # Secret key used for JWT token generation

# Note: Copy this file to .env and update the values according to your setup
# Do not commit .env file to version control (it's already in .gitignore)
